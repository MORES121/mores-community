    "text": "人生有幾多個十年",
    "source": "movie"
  },
  {
    "text": "做人最緊要係開心",
    "source": "movie"
  },
  {
    "text": "我哋係一家人",
    "source": "movie"
  },
  {
    "text": "呢個世界冇免費午餐",
    "source": "movie"
  },
  {
    "text": "做人要有骨氣",
    "source": "movie"
  },
  {
    "text": "機會係留俾有準備嘅人",
    "source": "movie"
  },
  {
    "text": "人生如戲，戲如人生",
    "source": "movie"
  },
  {
    "text": "珍惜眼前人",
    "source": "movie"
  },
  {
    "text": "笑一笑，世界更美妙",
    "source": "movie"
  },
  {
    "text": "夢想係要靠自己實現",
    "source": "movie"
  },
  {
    "text": "友誼永固",
    "source": "movie"
  },
  {
    "text": "愛要及時",
    "source": "movie"
  },
  {
    "text": "人生冇Take Two",
    "source": "movie"
  },
  {
    "text": "努力就會成功",
    "source": "movie"
  },
  {
    "text": "堅持到最後",
    "source": "movie"
  },
  {
    "text": "人生總有起跌",
    "source": "movie"
  },
  {
    "text": "希望永遠在明天",
    "source": "movie"
  },
  {
    "text": "相信自己",
    "source": "movie"
  },
  {
    "text": "勇氣可嘉",
    "source": "movie"
  },
  {
    "text": "智慧勝過財富",
    "source": "movie"
